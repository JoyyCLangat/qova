# Qova API Environment Variables
PORT=3001
RPC_URL=https://sepolia.base.org
DEPLOYER_PRIVATE_KEY=0x...

# Convex connection
CONVEX_URL=https://your-project.convex.cloud

# Shared secret for API server -> Convex HTTP actions (key management, usage tracking)
# Generate with: openssl rand -hex 32
CONVEX_SERVICE_SECRET=your-secret-here

NODE_ENV=development
